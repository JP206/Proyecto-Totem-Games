# =============================================================================
# E2E / load test configuration (per developer, NEVER commit the real .env.e2e)
# -----------------------------------------------------------------------------
# Copy this file to ".env.e2e" and fill in your own values:
#     cp .env.e2e.example .env.e2e        (PowerShell: Copy-Item .env.e2e.example .env.e2e)
#
# .env.e2e is gitignored. Only this *.example template is committed.
# =============================================================================

# --- GitHub authentication (REQUIRED for any real-GitHub test) ---------------
# Classic PAT with "repo" + "user" scopes (same token you paste into the app login).
E2E_GITHUB_TOKEN=

# Optional: your GitHub login. If empty, it is fetched from the token at runtime.
E2E_GITHUB_LOGIN=

# --- Dedicated, throwaway test repo (REQUIRED for Notes/Issues/Contexts tests)
# Format: owner/name  e.g. your-user/totem-e2e-sandbox
# Used as `current_project`. Tests create + clean up issues/notes/files here.
E2E_TEST_REPO=

# --- Sandbox repo for the translation "upload" push test (optional) ----------
# Format: owner/name. If empty, the upload test stubs the push instead.
E2E_SANDBOX_REPO=

# --- Real AI keys (only needed for `npm run test:e2e:real` / test:load:real) --
# Leave empty for the default mocked runs.
E2E_OPENAI_API_KEY=
E2E_GEMINI_API_KEY=

# --- Opt-in switches ---------------------------------------------------------
# Set to 1 to allow DESTRUCTIVE real-GitHub operations (Projects create/delete,
# pushing to the shared general repo). Off by default so CI never mutates repos.
E2E_ALLOW_DESTRUCTIVE=0

# Set to 1 to use the real OpenAI/Gemini APIs instead of the deterministic mock.
# (Normally set via `npm run test:e2e:real` which exports E2E_REAL_AI=1.)
E2E_REAL_AI=0
