{
  "name": "proyecto-totem-games-app",
  "version": "1.0.0",
  "description": "Aplicación de escritorio para localizar videojuegos",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watch",
    "test:coverage": "jest --watchAll=false --coverage",
    "probar": "(if exist dist rmdir /s /q dist) && cd src/renderer && (if exist build rmdir /s /q build) && npm run build && cd ../.. && npm start",
    "inicializar_proy": "npm install --legacy-peer-deps && cd src/renderer && npm install --legacy-peer-deps && cd ../.. && npm run probar",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fix_probar": "cd src/renderer && npm run build && cd ../.. && npm start",
    "pack-win": "npm run build && electron-builder --win --publish never -c.extraMetadata.main=dist/main/index.js"
  },
  "dependencies": {
    "@dqbd/tiktoken": "^1.0.22",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.6.0",
    "dotenv": "^16.4.6",
    "electron-store": "^8.2.0",
    "isomorphic-git": "^1.36.2",
    "lucide-react": "^0.563.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.12.0",
    "react-scripts": "^5.0.1",
    "web-vitals": "^5.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.30",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^8.2.2",
    "electron": "^27.3.11",
    "electron-builder": "^26.4.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.2.5",
    "typescript": "4.9.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.totem.gamesapp",
    "productName": "Totem Games App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/renderer/build/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/renderer/build",
        "to": "renderer/build"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "dist/main/index.js"
    }
  }
}